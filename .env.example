# Copy this file to .env and adjust values before running docker compose up.
# Never commit .env — it is in .gitignore.

# ── b2bdbg ──────────────────────────────────────────────────────────────────
# (env-var names retain the B2BD_ prefix as a short, stable namespace — like
#  rg for ripgrep — even though the binary/project is b2bdbg.)
# Host port that maps to b2bdbg :8080 (proxy + /metrics + /healthz)
B2BD_PORT=8080

# Log verbosity: debug | info | warn | error
B2BD_LOG_LEVEL=info

# Upstream Telegram Bot API base URL for the composed b2bdbg. Leave unset for
# the default https://api.telegram.org (the normal "point your own bot at the
# proxy" path). The offline demo profile overrides this to the in-process mock
# served by support-team-demo; `make compose-demo` sets it for you, so you do
# NOT need to set it here for the default path:
#   B2BD_TELEGRAM_BASE_URL=http://support-team-demo:8081
#
# Note: the composed b2bdbg always exports OTLP traces to the composed Jaeger
# (B2BD_OTEL_ENDPOINT=jaeger:4317, hardcoded in docker-compose.yml) and exposes
# /metrics on :8080, which the composed Prometheus scrapes. No env needed.

# ── Jaeger ──────────────────────────────────────────────────────────────────
# Jaeger UI port on the host
JAEGER_UI_PORT=16686

# ── Prometheus ──────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_PORT=3000
# Change before exposing to the internet
GRAFANA_ADMIN_PASSWORD=admin

# Token-cost estimate rate (USD per 1,000 tokens). 0 = cost metric stays 0
# (honest default). Set e.g. 0.50 to populate the Grafana cost panels.
B2BD_COST_PER_K_TOKENS=0

# Grafana default UI theme: light (default, clean for screenshots) or dark.
GRAFANA_THEME=light
